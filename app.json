{
  "expo": {
    "name": "Game Hub",
    "slug": "game-hub",
    "scheme": "game-hub",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "web": {
